{
  "metadata": {
    "workflow_name": "Segmentation Only with VTP Export",
    "workflow_version": "1.0.0",
    "created_date": "2025-12-19T00:00:00"
  },
  "global_settings": {
    "output_directory": "../output_SECOS_segmentation_only",
    "parallel_processing": true,
    "max_workers": 4,
    "save_individual_results": true,
    "coordinate_system": "EPSG:21781"
  },
  "workflow_dag": {
    "step_1_load_data": {
      "hypocenter_file": "../data_examples/SECOS_20250305_HyFI.csv",
      "hypocenter_separator": ",",
      "focal_mechanism_file": "../data_examples/SECOS_20250305_FM_HyFI.csv",
      "focal_mechanism_separator": ","
    },
    "step_2_catalog_segmentation": {
      "enabled": true,
      "segmentation_steps": [
        {
          "step_name": "Class A",
          "method": "dbscan",
          "features": ["spatial"],
          "cluster_dimension": "3d",
          "dbscan_eps": 350.0,
          "dbscan_min_samples": 10,
          "dbscan_metric": "euclidean",
          "min_cluster_size": 20,
          "process_outliers": true,
          "outlier_handling": "next_step"
        },
        {
          "step_name": "Class B",
          "method": "dbscan",
          "features": ["spatial"],
          "cluster_dimension": "3d",
          "dbscan_eps": 500.0,
          "dbscan_min_samples": 10,
          "dbscan_metric": "euclidean",
          "min_cluster_size": 10,
          "process_outliers": true,
          "outlier_handling": "next_step"
        }
      ],
      "final_outlier_handling": "keep",
      "max_outlier_ratio": 0.7
    },
    "step_3_per_sequence_analysis": {
      "description": "Export VTP files for each sequence (no fault analysis)",
      "fault_network": {
        "enabled": false
      },
      "model_validation": {
        "enabled": false
      },
      "auto_classification": {
        "enabled": false
      },
      "stress_analysis": {
        "enabled": false
      },
      "visualization": {
        "enabled": true,
        "parameters": {
          "basic_visualization": {
            "generate_3d_model": true,
            "generate_stereonet": false
          },
          "fault_surface_interpolation": {
            "enable_plane_interpolation": false,
            "enable_mesh_stress": false
          },
          "3d_export": {
            "export_vtp": true,
            "export_obj": false
          }
        }
      }
    },
    "step_4_merge_and_export": {
      "enabled": true,
      "description": "Merge VTP files from individual sequences",
      "merge_vtp_files": true,
      "sql_database": {
        "enabled": false
      },
      "merged_output": {
        "merged_vtp_path": "./output_SECOS_segmentation_only/merged_sequences.vtp",
        "export_merged_csv": true,
        "export_summary_statistics": true
      }
    }
  }
}
